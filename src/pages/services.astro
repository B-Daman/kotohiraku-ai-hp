---
import BaseLayout from "../layouts/BaseLayout.astro";
import Lightbox from "../components/Lightbox.astro";
import { services, faq } from "../data/siteConfig";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const subscription = services[0];
const workshop = services[1];
const support = services[2];
---

<BaseLayout title="サービス" description="AI導入サブスク、実務プロンプト講座、おたすけサポート、AIラボ（コミュニティ）で、あなたのAI活用を支援します。">
  <!-- ページヘッダー -->
  <section class="bg-primary py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">サービス</h1>
      <p class="text-white/70 max-w-2xl mx-auto text-sm">
        お客様の課題に合わせたサポートメニューとコミュニティをご用意しています
      </p>
    </div>
  </section>

  <!-- サービス一覧カード -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={`#${service.id}`}
            class="group block bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow border border-base-dark text-center"
          >
            <p class="text-accent text-xs font-medium mb-2">{service.target}</p>
            <p class="text-text-light text-sm mb-4">{service.painPoint}</p>
            <div class="text-3xl mb-3">{service.icon}</div>
            <h3 class="text-lg font-bold text-primary mb-2 group-hover:text-accent transition-colors">
              {service.title}
            </h3>
            <p class="text-primary font-bold">{service.topPrice}</p>
            <div class="mt-4 text-accent text-sm font-medium">
              詳しく見る →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- サービス①: AI導入サブスク -->
  <section id="subscription" class="bg-white py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- ヘッダー -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">💬</span>
          <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">{subscription.target}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">{subscription.title}</h2>
        <p class="text-text-light max-w-3xl">
          {subscription.description}
        </p>
      </div>

      <!-- 説明（左）+ プラン一覧（右） -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- 左: イメージ画像 -->
        <img
          src={`${base}/images/service-subscription-web.png`}
          alt="AI導入サブスクのイメージ：コンサルタントと経営者が一緒にPC画面を見ながらAI業務フローを設計している様子"
          class="w-full rounded-xl"
        />

        <!-- 右: プラン + CTA -->
        <div>
          <div class="space-y-3 mb-6">
            {subscription.plans?.map((plan) => (
              <div class:list={[
                "rounded-xl p-4 border-2",
                plan.recommended
                  ? "border-accent bg-base relative"
                  : "border-base-dark bg-base",
              ]}>
                {plan.recommended && (
                  <span class="absolute -top-2.5 right-4 bg-accent text-white text-[10px] font-medium px-3 py-0.5 rounded-full">
                    おすすめ
                  </span>
                )}
                <div class="flex items-baseline justify-between">
                  <h3 class="text-sm font-bold text-primary">{plan.name}</h3>
                  <div>
                    <span class="text-lg font-bold text-primary">{plan.price}</span>
                    <span class="text-text-light text-xs">{plan.period}</span>
                  </div>
                </div>
                <ul class="flex flex-wrap gap-x-4 gap-y-1 mt-2">
                  {plan.features.map((feature) => (
                    <li class="flex items-center gap-1 text-xs text-text-light">
                      <span class="text-accent">✓</span>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <a
            href={`${base}/contact`}
            class="inline-flex items-center justify-center w-full bg-accent text-white px-8 py-3 rounded-lg font-medium hover:bg-accent-dark transition-colors"
          >
            無料で相談する
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- サービス②: 実務プロンプト講座 -->
  <section id="workshop" class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- ヘッダー -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">📝</span>
          <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">{workshop.target}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">{workshop.title}</h2>
        <p class="text-text-light max-w-3xl">
          最大3名の少人数制。自分の業務に使えるプロンプトを一緒に作って持ち帰れます。
        </p>
      </div>

      <!-- 画像+チラシ（左）+ 詳細（右） -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- 左: イメージ画像 + チラシ -->
        <div>
          <img
            src={`${base}/images/service-prompt-course-web.png`}
            alt="実務プロンプト講座のイメージ：講師がプロジェクター画面の横で説明し、受講者がPCで実践している様子"
            class="w-full rounded-xl mb-4"
          />
          <div class="flex gap-3 justify-center">
            <img src={`${base}/images/flyer-workshop-front.webp`} alt="実務プロンプト講座チラシ 表面" class="flyer-thumb w-36 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
            <img src={`${base}/images/flyer-workshop-back.webp`} alt="実務プロンプト講座チラシ 裏面" class="flyer-thumb w-36 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
          </div>
        </div>

        <!-- 右: 詳細 + CTA -->
        <div>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>業務課題に合わせたカスタマイズ内容</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>議事録作成、メール効率化など実務直結</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>少人数制で質問しやすい環境</span>
            </li>
          </ul>
          <div class="flex items-baseline gap-2 mb-6">
            <span class="text-2xl font-bold text-primary">{workshop.pricing.price}</span>
            <span class="text-text-light text-sm">{workshop.pricing.unit}</span>
          </div>
          <a
            href={`${base}/contact`}
            class="inline-flex items-center justify-center w-full bg-accent text-white px-6 py-3 rounded-lg font-medium hover:bg-accent-dark transition-colors"
          >
            講座を申し込む
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- サービス③: おたすけサポート -->
  <section id="support" class="bg-white py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- ヘッダー -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">🚲</span>
          <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">{support.target}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">{support.title}</h2>
        <p class="text-text-light max-w-3xl">
          {support.description}
        </p>
      </div>

      <!-- 画像+チラシ（左）+ 詳細（右） -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- 左: イメージ画像 + チラシ -->
        <div>
          <img
            src={`${base}/images/service-support-web.png`}
            alt="おたすけサポートのイメージ：おばあさんの自宅でパソコンの使い方を一緒に解決している様子"
            class="w-full rounded-xl mb-4"
          />
          <div class="flex gap-3 justify-center">
            <img src={`${base}/images/flyer-support-front.webp`} alt="おたすけサポートチラシ 表面" class="flyer-thumb w-36 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
            <img src={`${base}/images/flyer-support-back.webp`} alt="おたすけサポートチラシ 裏面" class="flyer-thumb w-36 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
          </div>
        </div>

        <!-- 右: 詳細 + CTA -->
        <div>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>プリンター・Wi-Fi接続サポート</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>AI（ChatGPT等）の初期設定</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>パソコン・スマホの基本操作支援</span>
            </li>
          </ul>
          <div class="flex flex-wrap items-baseline gap-4 mb-6 text-sm">
            <span class="font-bold text-primary text-lg">¥5,000<span class="text-sm text-text-light font-normal"> / 60分</span></span>
            <span class="text-text-light">延長 ¥2,500 / 30分</span>
          </div>
          <p class="text-text-lighter text-xs mb-4">琴平町内（自転車20分圏）</p>
          <a
            href={`${base}/contact`}
            class="inline-flex items-center justify-center w-full bg-accent text-white px-6 py-3 rounded-lg font-medium hover:bg-accent-dark transition-colors"
          >
            サポートを依頼する
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ことひらくAIラボ（コミュニティ） -->
  <section id="community" class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- ヘッダー -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">🎓</span>
          <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">AIに興味がある方へ</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">ことひらくAIラボ</h2>
        <p class="text-text-light max-w-3xl">
          「ChatGPT、触ってみたけど…その先がわからない」――セミナーで学んだその先を、あっきーと仲間と一緒に。
        </p>
      </div>

      <!-- 画像（左）+ 詳細（右） -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
        <!-- 左: イメージ画像 -->
        <img
          src={`${base}/images/service-ai-lab-web.png`}
          alt="ことひらくAIラボのイメージ：Discordを通じてオンラインでつながった参加者たちがAIについて学び合っている様子"
          class="w-full rounded-xl"
        />

        <!-- 右: 詳細 + CTA -->
        <div>
          <h3 class="font-bold text-primary mb-3 text-sm">AIラボでできること</h3>
          <ul class="space-y-2 text-sm text-text-light mb-6">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>月1回のAI勉強会（2時間）＋アーカイブ視聴</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>AIに関する質問・相談</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>最新AI情報の共有</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>メンバー同士の情報交換</span>
            </li>
          </ul>
          <div class="mb-2">
            <span class="text-2xl font-bold text-primary">月額 ¥1,000</span>
            <span class="text-text-light text-sm ml-2">Discordで運営</span>
          </div>
          <p class="text-text-lighter text-xs mb-6">※ 30日間無料でお試しいただけます</p>
          <a
            href="https://page.theapps.jp/paid/join/B8hv3G40M25l69n5"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-full bg-accent text-white px-8 py-3 rounded-lg font-medium hover:bg-accent-dark transition-colors"
          >
            AIラボに参加する
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-primary text-center mb-12">よくある質問</h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <div class="bg-base rounded-xl p-6">
            <h3 class="font-bold text-primary mb-3 flex items-start gap-2">
              <span class="text-accent flex-shrink-0">Q.</span>
              {item.question}
            </h3>
            <div class="flex items-start gap-2 pl-1">
              <span class="text-primary font-bold flex-shrink-0">A.</span>
              <p class="text-text-light text-sm leading-relaxed">
                {item.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-accent py-8 md:py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        まずは気軽にご相談ください
      </h2>
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">
        30分の無料相談で、あなたの業務にAIが使えるかどうかをお伝えします。
      </p>
      <a
        href={`${base}/contact`}
        class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
      >
        無料で相談する
      </a>
    </div>
  </section>
  <Lightbox />
</BaseLayout>
