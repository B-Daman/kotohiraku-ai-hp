---
import BaseLayout from "../layouts/BaseLayout.astro";
import Lightbox from "../components/Lightbox.astro";
import { services, faq } from "../data/siteConfig";

const base = import.meta.env.BASE_URL;

const subscription = services[0];
const workshop = services[1];
const support = services[2];
---

<BaseLayout title="サービス" description="AI導入サブスク、実務プロンプト講座、おたすけサポート、AIラボ（コミュニティ）で、あなたのAI活用を支援します。">
  <!-- ページヘッダー -->
  <section class="bg-primary py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">サービス</h1>
      <p class="text-white/70 max-w-2xl mx-auto text-sm">
        お客様の課題に合わせたサポートメニューとコミュニティをご用意しています
      </p>
    </div>
  </section>

  <!-- サービス一覧カード -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {services.map((service) => (
          <a
            href={`#${service.id}`}
            class="group block bg-white rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow border border-base-dark text-center"
          >
            <p class="text-accent text-xs font-medium mb-2">{service.target}</p>
            <p class="text-text-light text-sm mb-4">{service.painPoint}</p>
            <div class="text-3xl mb-3">{service.icon}</div>
            <h3 class="text-lg font-bold text-primary mb-2 group-hover:text-accent transition-colors">
              {service.title}
            </h3>
            <p class="text-primary font-bold">{service.topPrice}</p>
            <div class="mt-4 text-accent text-sm font-medium">
              詳しく見る →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- サービス①: AI導入サブスク -->
  <section id="subscription" class="bg-white py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-3xl">💬</span>
          <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">{subscription.target}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">{subscription.title}</h2>
        <p class="text-text-light max-w-3xl">
          {subscription.description}
        </p>
      </div>

      <!-- メインプラン（3枚） -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        {subscription.plans?.map((plan) => (
          <div class:list={[
            "rounded-2xl p-6 border-2 transition-shadow",
            plan.recommended
              ? "border-accent shadow-lg bg-base relative"
              : "border-base-dark bg-base hover:shadow-md",
          ]}>
            {plan.recommended && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-accent text-white text-xs font-medium px-4 py-1 rounded-full">
                おすすめ
              </div>
            )}
            <h3 class="text-lg font-bold text-primary mb-2">{plan.name}</h3>
            <div class="mb-4">
              <span class="text-2xl font-bold text-primary">{plan.price}</span>
              <span class="text-text-light text-sm">{plan.period}</span>
            </div>
            <ul class="space-y-2">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-text-light">
                  <span class="text-accent mt-0.5">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- ライトプラン（別枠） -->
      <div class="border border-base-dark rounded-xl p-6 bg-base">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <h3 class="font-bold text-primary">{subscription.lightPlan.name}</h3>
              <span class="text-xs text-text-lighter bg-base-dark px-2 py-0.5 rounded">
                {subscription.lightPlan.note}
              </span>
            </div>
            <ul class="flex flex-wrap gap-4 text-sm text-text-light">
              {subscription.lightPlan.features.map((feature) => (
                <li class="flex items-center gap-1">
                  <span class="text-accent">✓</span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="text-right flex-shrink-0">
            <span class="text-xl font-bold text-primary">{subscription.lightPlan.price}</span>
            <span class="text-text-light text-sm">{subscription.lightPlan.period}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- サービス②: 実務プロンプト講座 -->
  <section id="workshop" class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto] gap-8 items-center">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="text-3xl">📝</span>
            <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">{workshop.target}</span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">{workshop.title}</h2>
          <p class="text-text-light mb-4">
            {workshop.description}
          </p>
          <ul class="space-y-2 text-sm text-text-light mb-4">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>業務課題に合わせたカスタマイズ内容</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>議事録作成、メール効率化など実務直結</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>少人数制で質問しやすい環境</span>
            </li>
          </ul>
          <div class="flex items-baseline gap-2 mb-4">
            <span class="text-2xl font-bold text-primary">{workshop.pricing.price}</span>
            <span class="text-text-light text-sm">{workshop.pricing.unit}</span>
          </div>
          <a
            href={`${base}/contact`}
            class="inline-flex items-center justify-center bg-accent text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-accent-dark transition-colors"
          >
            講座を申し込む
          </a>
        </div>
        <img src={`${base}/images/flyer-workshop-front.webp`} alt="実務プロンプト講座チラシ 表面" class="flyer-thumb hidden md:block w-64 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
        <img src={`${base}/images/flyer-workshop-back.webp`} alt="実務プロンプト講座チラシ 裏面" class="flyer-thumb hidden md:block w-64 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
      </div>
      <!-- モバイル用チラシサムネイル -->
      <div class="flex gap-4 mt-6 md:hidden">
        <img src={`${base}/images/flyer-workshop-front.webp`} alt="実務プロンプト講座チラシ 表面" class="flyer-thumb w-44 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
        <img src={`${base}/images/flyer-workshop-back.webp`} alt="実務プロンプト講座チラシ 裏面" class="flyer-thumb w-44 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
      </div>
    </div>
  </section>

  <!-- サービス③: おたすけサポート -->
  <section id="support" class="bg-white py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-[auto_auto_1fr] gap-8 items-center">
        <img src={`${base}/images/flyer-support-front.webp`} alt="おたすけサポートチラシ 表面" class="flyer-thumb hidden md:block w-64 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
        <img src={`${base}/images/flyer-support-back.webp`} alt="おたすけサポートチラシ 裏面" class="flyer-thumb hidden md:block w-64 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="text-3xl">🚲</span>
            <span class="text-xs font-medium text-accent bg-accent/10 px-3 py-1 rounded-full">{support.target}</span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-primary mb-4">{support.title}</h2>
          <p class="text-text-light mb-4">
            {support.description}
          </p>
          <ul class="space-y-2 text-sm text-text-light mb-4">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>プリンター・Wi-Fi接続サポート</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>AI（ChatGPT等）の初期設定</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>パソコン・スマホの基本操作支援</span>
            </li>
          </ul>
          <div class="flex flex-wrap items-baseline gap-4 mb-4 text-sm">
            <span class="font-bold text-primary text-lg">¥5,000<span class="text-sm text-text-light font-normal"> / 60分</span></span>
            <span class="text-text-light">延長 ¥2,500 / 30分</span>
            <span class="text-text-light">琴平町内（自転車20分圏）</span>
          </div>
          <a
            href={`${base}/contact`}
            class="inline-flex items-center justify-center bg-accent text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-accent-dark transition-colors"
          >
            サポートを依頼する
          </a>
        </div>
      </div>
      <!-- モバイル用チラシサムネイル -->
      <div class="flex gap-4 mt-6 md:hidden">
        <img src={`${base}/images/flyer-support-front.webp`} alt="おたすけサポートチラシ 表面" class="flyer-thumb w-44 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
        <img src={`${base}/images/flyer-support-back.webp`} alt="おたすけサポートチラシ 裏面" class="flyer-thumb w-44 rounded-lg shadow-sm border border-base-dark cursor-pointer hover:opacity-80 transition-opacity" />
      </div>
    </div>
  </section>

  <!-- ことひらくAIラボ（コミュニティ） -->
  <section id="community" class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="bg-white rounded-2xl p-8 md:p-12 border border-accent/20 shadow-sm">
        <div class="text-center mb-8">
          <span class="text-3xl mb-3 block">🎓</span>
          <h2 class="text-2xl md:text-3xl font-bold text-primary mb-3">ことひらくAIラボ</h2>
          <p class="text-text-light max-w-2xl mx-auto">
            「ChatGPT、触ってみたけど…その先がわからない」<br />
            セミナーで学んだその先を、あっきーと仲間と一緒に。
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <h3 class="font-bold text-primary mb-3">AIラボでできること</h3>
            <ul class="space-y-2 text-sm text-text-light">
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">✓</span>
                <span>月1回のAI勉強会（2時間）＋アーカイブ視聴</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">✓</span>
                <span>AIに関する質問・相談</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">✓</span>
                <span>最新AI情報の共有</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">✓</span>
                <span>メンバー同士の情報交換</span>
              </li>
            </ul>
          </div>
          <div>
            <h3 class="font-bold text-primary mb-3">こんな方におすすめ</h3>
            <ul class="space-y-2 text-sm text-text-light">
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">―</span>
                <span>セミナーの後も学び続けたい</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">―</span>
                <span>AIの最新情報をゆるく追いたい</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">―</span>
                <span>気軽にAIの相談ができる場がほしい</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-accent mt-0.5">―</span>
                <span>あっきーの活動を応援したい</span>
              </li>
            </ul>
          </div>
        </div>

        <div class="text-center">
          <div class="mb-4">
            <span class="text-2xl font-bold text-primary">月額 ¥1,000</span>
            <span class="text-text-light text-sm ml-2">Discordで運営・全国どこからでも参加OK</span>
          </div>
          <p class="text-text-lighter text-xs mb-4">※ 初月無料でお試しいただけます</p>
          <a
            href={`${base}/contact`}
            class="inline-flex items-center justify-center bg-accent text-white px-8 py-3 rounded-lg font-medium hover:bg-accent-dark transition-colors"
          >
            AIラボに参加する
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-2xl md:text-3xl font-bold text-primary text-center mb-12">よくある質問</h2>
      <div class="space-y-4">
        {faq.map((item) => (
          <div class="bg-base rounded-xl p-6">
            <h3 class="font-bold text-primary mb-3 flex items-start gap-2">
              <span class="text-accent flex-shrink-0">Q.</span>
              {item.question}
            </h3>
            <div class="flex items-start gap-2 pl-1">
              <span class="text-primary font-bold flex-shrink-0">A.</span>
              <p class="text-text-light text-sm leading-relaxed">
                {item.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-accent py-8 md:py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        まずは気軽にご相談ください
      </h2>
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">
        30分の無料相談で、あなたの業務にAIが使えるかどうかをお伝えします。
      </p>
      <a
        href={`${base}/contact`}
        class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
      >
        無料で相談する
      </a>
    </div>
  </section>
  <Lightbox />
</BaseLayout>
