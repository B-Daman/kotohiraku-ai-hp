---
import BaseLayout from "../layouts/BaseLayout.astro";
import { socialLinks } from "../data/siteConfig";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const contactFormUrl = "https://forms.gle/QCUAV1sQgX44ZQvp9";
---

<BaseLayout title="お問い合わせ" description="ことひらくAIへのお問い合わせ。AI導入相談、セミナー、訪問サポートについてお気軽にご連絡ください。">
  <!-- ページヘッダー -->
  <section class="bg-primary py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">お問い合わせ</h1>
      <p class="text-white/70 max-w-2xl mx-auto text-sm">
        AI活用についてのご相談、お気軽にお問い合わせください
      </p>
    </div>
  </section>

  <!-- 安心材料（3カード横並び） -->
  <section class="py-10 md:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl p-6 border border-base-dark text-center">
          <div class="text-2xl mb-2">💰</div>
          <h3 class="font-bold text-primary mb-1">初回相談無料</h3>
          <p class="text-text-light text-sm">30分〜60分の無料相談で、お悩みをお聞きします。お気軽にどうぞ。</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-base-dark text-center">
          <div class="text-2xl mb-2">📩</div>
          <h3 class="font-bold text-primary mb-1">2営業日以内に返信</h3>
          <p class="text-text-light text-sm">フォーム送信後、メールにてご連絡いたします。</p>
        </div>
        <div class="bg-white rounded-xl p-6 border border-base-dark text-center">
          <div class="text-2xl mb-2">📍</div>
          <h3 class="font-bold text-primary mb-1">対応エリア</h3>
          <p class="text-text-light text-sm">琴平町近隣は対面で訪問。遠方の方はオンラインでも対応可能です。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 相談例 + SNS -->
  <section class="bg-white py-10 md:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- お問い合わせ内容の例 -->
        <div class="bg-base rounded-xl p-6 border border-base-dark">
          <h3 class="font-bold text-primary mb-4">こんなことを相談できます</h3>
          <ul class="space-y-2 text-sm text-text-light">
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>AIをどう業務に活かせるか知りたい</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>セミナーを開催してほしい</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>パソコンの設定で困っている</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>ChatGPTの使い方を教えてほしい</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent mt-0.5">✓</span>
              <span>AI導入の継続サポートがほしい</span>
            </li>
          </ul>
        </div>

        <!-- SNSリンク -->
        <div class="bg-base rounded-xl p-6 border border-base-dark">
          <h3 class="font-bold text-primary mb-4">SNSでつながる</h3>
          <p class="text-text-light text-sm mb-4">お急ぎの場合はSNSからもご連絡いただけます。</p>
          <div class="space-y-3">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-text-light hover:text-accent transition-colors text-sm py-2"
              >
                <span class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center text-primary text-xs font-bold">
                  {link.icon === "x" ? "X" : "N"}
                </span>
                <span>{link.name}</span>
                <span class="ml-auto text-text-lighter">↗</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Form -->
  <section class="py-10 md:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="bg-white rounded-2xl p-8 border border-base-dark">
        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLSfrEVdl9hKyFoqCgOks2oLnYLmDL16XNnHQ3vbrGDYoMMV5ug/viewform?embedded=true"
          width="100%"
          height="1492"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          class="rounded-lg"
        >読み込んでいます…</iframe>
      </div>
    </div>
  </section>

  <!-- QRコード + URL -->
  <section class="bg-white py-10 md:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-text-light text-sm mb-4">スマホからもお問い合わせいただけます</p>
      <img src={`${base}/images/qr-contact.png`} alt="お問い合わせフォームQRコード" class="mx-auto mb-4" style="width: 168px; height: 168px;" />
      <a
        href={contactFormUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent text-sm font-medium hover:text-accent-dark transition-colors"
      >
        {contactFormUrl}
      </a>
    </div>
  </section>
</BaseLayout>
