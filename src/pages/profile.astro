---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig, timeline, mediaAppearances, communityStats } from "../data/siteConfig";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="プロフィール" description="ことひらくAI代表・秋吉一輝（あっきー）のプロフィール。琴平町地域おこし協力隊として活動中。">
  <!-- ページヘッダー -->
  <section class="bg-primary py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white">プロフィール</h1>
    </div>
  </section>

  <!-- プロフィール + 大切にしていること -->
  <section class="py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col md:flex-row items-center md:items-start gap-10 md:gap-14">
        <!-- 左: 大切にしていること -->
        <div class="flex-1 order-2 md:order-1">
          <h3 class="text-xl font-bold text-primary mb-6">大切にしていること</h3>
          <blockquote class="text-lg md:text-xl text-primary font-bold mb-6 leading-relaxed">
            「難しいことを、わかりやすく」
          </blockquote>
          <p class="text-text-light leading-relaxed">
            大切なのは、AIの知識ではなく、あなたの業務が少しラクになること。専門的な話は私が引き受けます。あなたは「こういう作業が面倒なんだよね」と教えてください。
          </p>
        </div>
        <!-- 右: プロフィール写真・名前・肩書き -->
        <div class="text-center flex-shrink-0 order-1 md:order-2">
          <img
            src={`${base}/images/profile-photo.webp`}
            alt="秋吉一輝（あっきー）"
            class="w-44 h-44 md:w-52 md:h-52 rounded-full mx-auto mb-4 object-cover"
          />
          <h2 class="text-2xl md:text-3xl font-bold text-primary mb-2">
            {siteConfig.representative}
          </h2>
          <p class="text-accent font-medium">ことひらくAI 代表</p>
          <p class="text-text-light text-sm mt-1">琴平町地域おこし協力隊</p>
          <p class="text-text-light text-sm">琴平町DAOコミュニティマネージャー</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 強み・特徴 -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h3 class="text-xl font-bold text-primary mb-8 text-center">強み・特徴</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-base rounded-xl p-6 border border-base-dark">
          <div class="text-2xl mb-3">🏛️</div>
          <h4 class="font-bold text-primary mb-2">三層構造の活動</h4>
          <p class="text-text-light text-sm">
            行政（役場DX）× 地域（DAO・セミナー）× 個人事業。
            多角的な視点から地域課題に取り組みます。
          </p>
        </div>
        <div class="bg-base rounded-xl p-6 border border-base-dark">
          <div class="text-2xl mb-3">⚡</div>
          <h4 class="font-bold text-primary mb-2">実践型</h4>
          <p class="text-text-light text-sm">
            「まず試す」スタイル。対面で即効性のあるAI活用を提供します。
          </p>
        </div>
        <div class="bg-base rounded-xl p-6 border border-base-dark">
          <div class="text-2xl mb-3">🌐</div>
          <h4 class="font-bold text-primary mb-2">全国ネットワーク</h4>
          <p class="text-text-light text-sm">
            DAO運営で全国200名超のコミュニティを構築。地域を超えた知見を活用します。
          </p>
        </div>
        <div class="bg-base rounded-xl p-6 border border-base-dark">
          <div class="text-2xl mb-3">📺</div>
          <h4 class="font-bold text-primary mb-2">メディア掲載多数</h4>
          <p class="text-text-light text-sm">
            地方でのAI活用の取り組みが、NHK・日経新聞・読売新聞など多数メディアに取り上げられています。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 経歴タイムライン -->
  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h3 class="text-xl font-bold text-primary mb-8 text-center">経歴</h3>
      <div class="space-y-0">
        {timeline.map((item, i) => (
          <div class="flex gap-4 md:gap-8">
            <div class="flex flex-col items-center">
              <div class:list={[
                "w-3 h-3 rounded-full mt-2",
                i === timeline.length - 1 ? "bg-accent" : "bg-primary/30",
              ]}></div>
              {i < timeline.length - 1 && (
                <div class="w-0.5 flex-1 bg-primary/10 my-1"></div>
              )}
            </div>
            <div class="pb-8">
              <div class="text-xs font-medium text-accent mb-1">{item.period}</div>
              <h4 class="font-bold text-primary">{item.title}</h4>
              {item.description && (
                <p class="text-text-light text-sm mt-1">{item.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- メディア掲載 -->
  <section class="bg-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <h3 class="text-xl font-bold text-primary mb-8 text-center">メディア掲載実績</h3>
        <div class="bg-white rounded-2xl border border-base-dark overflow-hidden">
          {(() => {
            const years = ["2026年", "2025年", "2024年"];
            return years.map((year) => {
              const items = mediaAppearances.filter((m) => m.date.startsWith(year.replace("年", "")));
              if (items.length === 0) return null;
              return (
                <div>
                  <div class="bg-primary/5 px-5 py-2">
                    <span class="text-sm font-bold text-primary">{year}</span>
                  </div>
                  {items.map((media, i) => (
                    <div class:list={["px-5 py-2 flex items-center gap-3", i < items.length - 1 ? "border-b border-base-dark" : ""]}>
                      <span class="text-text-lighter text-xs w-10 flex-shrink-0">{media.date.split("年")[1]}</span>
                      <span class="text-primary text-sm font-medium flex-shrink-0">{media.name}</span>
                      {"title" in media && media.title && (
                        <span class="text-text-light text-xs truncate min-w-0">{media.title}</span>
                      )}
                      {media.url ? (
                        <a href={media.url} target="_blank" rel="noopener noreferrer" class="text-accent text-xs font-medium hover:text-accent-dark transition-colors flex-shrink-0 ml-auto">
                          記事 →
                        </a>
                      ) : null}
                    </div>
                  ))}
                </div>
              );
            });
          })()}
        </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-accent py-8 md:py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        まずは気軽にご相談ください
      </h2>
      <p class="text-white/80 mb-8 max-w-2xl mx-auto">
        30分の無料相談で、あなたの業務にAIが使えるかどうかをお伝えします。
      </p>
      <a
        href={`${base}/contact`}
        class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
      >
        無料で相談する
      </a>
    </div>
  </section>
</BaseLayout>
